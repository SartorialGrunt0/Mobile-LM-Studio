param(
    [string]$Configuration = "Release",
    [string]$Runtime = "win-x64",
    [string]$OutputPath,
    [switch]$FrameworkDependent
)

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

$repoRoot = Split-Path -Parent $PSScriptRoot
$publishScript = Join-Path $repoRoot "scripts\publish.ps1"
$installerPath = Join-Path $repoRoot "artifacts\installer\MobileLmStudioSetup.exe"

$iscc = Get-Command iscc -ErrorAction SilentlyContinue
if (-not $iscc) {
    throw "Inno Setup Compiler (iscc) was not found on PATH. Install Inno Setup before running this script."
}

$publishArguments = @{
    Configuration = $Configuration
    Runtime = $Runtime
}

if ($OutputPath) {
    $publishArguments.OutputPath = $OutputPath
}

if (-not $FrameworkDependent.IsPresent) {
    $publishArguments.SelfContained = $true
}

& $publishScript @publishArguments

if (-not (Test-Path $installerPath)) {
    throw "The installer executable was not created at $installerPath."
}

Write-Host "Installer executable: $installerPath"
